{
  "name": "@zandoh/keysmith",
  "version": "0.3.2",
  "description": "Keyboard shortcut manager for the web: commands, scopes, sequences, and user remapping. Fast, headless, accessible, framework agnostic.",
  "keywords": [
    "a11y",
    "accessibility",
    "chords",
    "framework-agnostic",
    "headless",
    "hotkeys",
    "keybindings",
    "keyboard-shortcuts",
    "remapping",
    "sequences",
    "shortcut-manager",
    "shortcuts",
    "wcag"
  ],
  "homepage": "https://zandoh.github.io/keysmith/",
  "bugs": {
    "url": "https://github.com/zandoh/keysmith/issues"
  },
  "license": "MIT",
  "author": {
    "name": "zandoh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zandoh/keysmith.git"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "knip": "knip",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "check": "oxlint && oxfmt --check && tsc --noEmit && knip",
    "bump": "changeset version",
    "release": "changeset publish && bun scripts/release-github.ts",
    "prepare": "simple-git-hooks",
    "prepublishOnly": "bun run check && bun run test && bun run build",
    "changelog": "git-cliff -o CHANGELOG.md",
    "release:notes": "git-cliff --latest --strip header",
    "test:browser": "playwright test",
    "size": "bun scripts/size.ts"
  },
  "dependencies": {
    "@zandoh/tsbus": "^0.1.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "git-cliff": "^2.13.1",
    "happy-dom": "^20.10.6",
    "knip": "^5",
    "oxfmt": "^0",
    "oxlint": "^1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-git-hooks": "^2.13.1",
    "svelte": "^5.56.4",
    "tsup": "^8",
    "typescript": "^7",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.39"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run check && bun run test"
  },
  "engines": {
    "node": ">=18"
  }
}
